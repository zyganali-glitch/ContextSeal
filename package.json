{
  "name": "contextseal",
  "version": "0.1.0",
  "description": "Graph-backed certification for high-risk data changes",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "demo": "npm run demo:generate",
    "demo:generate": "node scripts/run-demo.js",
    "demo:check": "node scripts/run-demo.js --check",
    "datahub:seed": "uv run --with acryl-datahub==1.6.0.14 python scripts/seed-datahub.py --preflight",
    "datahub:seed:apply": "uv run --with acryl-datahub==1.6.0.14 python scripts/seed-datahub.py --apply",
    "datahub:seed:scope": "uv run --with acryl-datahub==1.6.0.14 python scripts/seed-datahub.py --print-scope",
    "datahub:properties": "uv run --with acryl-datahub==1.6.0.14 python scripts/upsert-datahub-properties.py --preflight",
    "datahub:properties:apply": "uv run --with acryl-datahub==1.6.0.14 python scripts/upsert-datahub-properties.py --apply",
    "datahub:properties:scope": "uv run --with acryl-datahub==1.6.0.14 python scripts/upsert-datahub-properties.py --print-scope",
    "datahub:safety:test": "python -m unittest discover -s tests_py -p test_*.py",
    "datahub:capture": "node scripts/capture-live-evidence.js",
    "datahub:export": "node scripts/export-live-run.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "check": "node scripts/check-repository.js",
    "evidence:check": "node scripts/validate-evidence.js",
    "smoke": "node scripts/smoke-server.js",
    "validate": "npm run check && npm run evidence:check && npm test && npm run demo:check && npm run smoke"
  },
  "keywords": [
    "datahub",
    "mcp",
    "data-lineage",
    "data-governance",
    "ai-agents",
    "dbt"
  ],
  "license": "Apache-2.0"
}
