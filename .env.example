# Runtime mode: fixture (safe local judge demo) or datahub (live MCP connection)
CONTEXTSEAL_MODE=fixture
PORT=4173

# Local DataHub Core uses the official stdio MCP server launched with uvx.
DATAHUB_MCP_TRANSPORT=stdio
DATAHUB_MCP_COMMAND=uvx
DATAHUB_MCP_ARGS=["mcp-server-datahub@latest"]
DATAHUB_GMS_URL=http://localhost:8080
# Keep secrets only in .env. Never commit a real token.
DATAHUB_GMS_TOKEN=
DATAHUB_MCP_MUTATIONS_ENABLED=false

# DataHub Cloud uses streamable HTTP instead:
# DATAHUB_MCP_TRANSPORT=http
# DATAHUB_MCP_URL=https://YOUR_TENANT.acryl.io/integrations/ai/mcp/

# Optional GitHub delivery. Leave disabled until the operator approves a run.
GITHUB_DELIVERY_ENABLED=false
GITHUB_REPOSITORY=
