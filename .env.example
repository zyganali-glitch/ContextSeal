# Runtime mode: fixture (safe local judge demo) or datahub (live MCP connection)
CONTEXTSEAL_MODE=fixture
CONTEXTSEAL_HOST=127.0.0.1
PORT=4173

# DataHub mode refuses to start until both values are set. Generate a separate,
# random ContextSeal operator token; this is NOT a DataHub credential. The UI
# keeps it in tab memory only. Limit the live API to explicit catalog targets.
CONTEXTSEAL_OPERATOR_TOKEN=
CONTEXTSEAL_ALLOWED_TARGET_URNS=[]

# Local DataHub Core uses the official stdio MCP server launched with uvx.
DATAHUB_MCP_TRANSPORT=stdio
DATAHUB_MCP_COMMAND=uvx
DATAHUB_MCP_ARGS=["mcp-server-datahub@0.6.0"]
DATAHUB_GMS_URL=http://localhost:8080
# Keep secrets only in .env. Never commit a real token. Some disposable local
# Core configurations have authentication disabled and therefore use a blank
# value; authenticated Core/Cloud environments require a scoped credential.
DATAHUB_GMS_TOKEN=
DATAHUB_MCP_MUTATIONS_ENABLED=false

# The seed/property helpers are read-only by default. Their --apply commands
# additionally require shell-scoped exact confirmations and the plan hash from
# the immediately preceding preflight. Keep these blank in files; see the live
# setup guide. Remote bootstrap adds an exact HTTPS endpoint and URN allowlist.
CONTEXTSEAL_DATAHUB_MUTATION_CONFIRMATION=
CONTEXTSEAL_SEED_CONFIRMATION=
CONTEXTSEAL_PROPERTIES_CONFIRMATION=
CONTEXTSEAL_APPROVED_BOOTSTRAP_PLAN_SHA256=
CONTEXTSEAL_REMOTE_DATAHUB_BOOTSTRAP=
CONTEXTSEAL_REMOTE_DATAHUB_ALLOWED_GMS_URLS=[]
CONTEXTSEAL_REMOTE_DATAHUB_SEED_URNS=[]
CONTEXTSEAL_REMOTE_DATAHUB_PROPERTY_URNS=[]

# DataHub Cloud uses streamable HTTP instead:
# DATAHUB_MCP_TRANSPORT=http
# DATAHUB_MCP_URL=https://YOUR_TENANT.acryl.io/integrations/ai/mcp/
